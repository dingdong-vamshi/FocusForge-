{
  "manifest_version": 3,
  "name": "FocusForge Tracker",
  "version": "1.0",
  "description": "Real-time activity tracking for the FocusForge productivity platform.",
  "permissions": [
    "tabs",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": { 
    "service_worker": "background.js" 
  },
  "action": {
    "default_popup": "popup.html"  
  }
}
